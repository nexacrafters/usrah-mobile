{
  "expo": {
    "name": "Usrah",
    "slug": "usrah",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "scheme": "usrah",
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#3d8b6f"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.nexacrafters.usrah",
      "infoPlist": {
        "NSCameraUsageDescription": "Allow Usrah to access your camera for photos and videos.",
        "NSPhotoLibraryUsageDescription": "Allow Usrah to access your photos.",
        "NSLocationWhenInUseUsageDescription": "Allow Usrah to access your location for prayer times and Qibla direction.",
        "NSMicrophoneUsageDescription": "Allow Usrah to access your microphone for voice messages."
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#3d8b6f"
      },
      "package": "com.nexacrafters.usrah",
      "edgeToEdgeEnabled": true,
      "permissions": [
        "android.permission.CAMERA",
        "android.permission.READ_EXTERNAL_STORAGE",
        "android.permission.WRITE_EXTERNAL_STORAGE",
        "android.permission.ACCESS_FINE_LOCATION",
        "android.permission.ACCESS_COARSE_LOCATION",
        "android.permission.RECORD_AUDIO",
        "android.permission.VIBRATE",
        "android.permission.USE_BIOMETRIC",
        "android.permission.USE_FINGERPRINT"
      ]
    },
    "web": {
      "favicon": "./assets/favicon.png",
      "bundler": "metro"
    },
    "plugins": [
      "expo-router",
      "expo-secure-store",
      "expo-local-authentication",
      [
        "expo-camera",
        {
          "cameraPermission": "Allow Usrah to access your camera."
        }
      ],
      [
        "expo-location",
        {
          "locationAlwaysAndWhenInUsePermission": "Allow Usrah to use your location for prayer times."
        }
      ],
      [
        "expo-image-picker",
        {
          "photosPermission": "Allow Usrah to access your photos."
        }
      ],
      [
        "expo-notifications",
        {
          "icon": "./assets/notification-icon.png",
          "color": "#3d8b6f"
        }
      ],
      "expo-localization"
    ],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "router": {
        "origin": false
      },
      "eas": {
        "projectId": "usrah-mobile"
      }
    }
  }
}
